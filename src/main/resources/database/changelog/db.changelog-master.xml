            <column name="nfcpayments" type="BOOLEAN"/>
            <column name="secureelemet_payments" type="BOOLEAN"/>
            <column name="irda" type="BOOLEAN"/>
            <column name="mhl" type="BOOLEAN"/>
            <column name="video_exit_to_display_port" type="BOOLEAN"/>
            <column name="slimport" type="BOOLEAN"/>
            <column name="usb" type="BOOLEAN"/>
            <column name="usb_host" type="BOOLEAN"/>
            <column name="usb_tethering" type="BOOLEAN"/>
        </createTable>
    </changeSet>
</databaseChangeLog>
